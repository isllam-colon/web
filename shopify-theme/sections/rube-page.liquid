{% comment %}Generic page section scaffold.{% endcomment %}

<div class="container-rube py-20" id="MainContent">
  {% if section.settings.heading != blank %}
    <h1>{{ section.settings.heading }}</h1>
  {% endif %}
  {{ page.content }}
</div>

{% schema %}
{
  "name": "RUBE Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": ""
    }
  ],
  "presets": [
    {
      "name": "RUBE Page"
    }
  ]
}
{% endschema %}

